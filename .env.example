# Application
APP_NAME=CertiFlow
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
<<<<<<< HEAD
