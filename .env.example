>>>>>>> 756b71d (fix: add production backend url configuration)

# Database
DATABASE_URL=postgresql+asyncpg://certiflow:certiflow@localhost:5432/certiflow
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Hashing
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://www.certfi.online"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# File Storage
STORAGE_TYPE=local
STORAGE_BASE_PATH=./app/storage
MAX_UPLOAD_SIZE=10485760
ALLOWED_TEMPLATE_EXTENSIONS=["png","jpg","jpeg","pdf"]
ALLOWED_PARTICIPANT_EXTENSIONS=["csv","xlsx"]

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
EMAIL_FROM=noreply@certiflow.com
EMAIL_FROM_NAME=CertiFlow

# Verification
VERIFICATION_BASE_URL=https://www.certfi.online/verify

# Watermark
DEFAULT_WATERMARK_OPACITY=0.3
DEFAULT_WATERMARK_TEXT=CertiFlow

# Certificate
CERTIFICATE_ID_PREFIX=CERT
CERTIFICATE_ID_FORMAT={prefix}-{year}-{sequence:06d}

# QR Code
QR_CODE_VERSION=1
QR_CODE_ERROR_CORRECTION=L
QR_CODE_BOX_SIZE=10
QR_CODE_BORDER=4

# Tamper Detection
TAMPER_SECRET_KEY=your-tamper-secret-key-change-in-production

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
